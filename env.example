# =============================================================================
# FOR VALIDATORS ONLY
# =============================================================================
# Copy this file to .env and fill in your API keys

# =============================================================================
# Network Configuration
# =============================================================================
SUBTENSOR_NETWORK=finney

# =============================================================================
# Supabase (REQUIRED)
# =============================================================================
SUPABASE_URL=https://qplwoislplkcegvdmbim.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# Sourcing Validation APIs (REQUIRED)
# =============================================================================

# TrueList - Email verification (Stage 3)
# https://truelist.io/
TRUELIST_API_KEY=your_truelist_api_key_here

# ScrapingDog - LinkedIn/Google Search validation (Stage 4 & 5)
# https://www.scrapingdog.com/
SCRAPINGDOG_API_KEY=your_scrapingdog_api_key_here

# OpenRouter - LLM inference for scoring
# https://openrouter.ai/
OPENROUTER_KEY=your_openrouter_key_here

# =============================================================================
# MINER SOURCING (Lead Sorcerer) — REQUIRED for miners to generate leads
# =============================================================================
# Without these, the miner will start but source 0 leads (see miner_models/lead_sorcerer_main/).
# GSE = Google Programmable Search (Custom Search JSON API)
#   - Create at: https://programmablesearchengine.google.com/
#   - GSE_CX = your Search engine ID
# Firecrawl: https://firecrawl.dev/ — web crawl/extract
# OpenRouter: same key as above (LLM for lead generation)
GSE_API_KEY=your_google_api_key_here
GSE_CX=your_search_engine_id_here
FIRECRAWL_KEY=your_firecrawl_key_here

# =============================================================================
# Qualification APIs (REQUIRED for model evaluation)
# =============================================================================
# These are SEPARATE keys from sourcing — used only for qualification
# model evaluation. Keeps billing and rate limits isolated.

QUALIFICATION_SCRAPINGDOG_API_KEY=your_qualification_scrapingdog_key_here
QUALIFICATION_OPENROUTER_API_KEY=your_qualification_openrouter_key_here

# Qualification leads table (set by deployment scripts)
QUALIFICATION_LEADS_TABLE=test_leads_for_miners

# =============================================================================
# Reputation Score APIs (OPTIONAL)
# =============================================================================
# Most reputation checks use free public APIs (no key needed):
# - Wayback Machine
# - SEC EDGAR
# - GDELT
# - WHOIS/DNSBL
#
# Optional paid APIs for enhanced reputation scoring:
COMPANIES_HOUSE_API_KEY=your_companies_house_key_here

# =============================================================================
# Optional: Hugging Face models for lead quality (miners)
# =============================================================================
# Requires: pip install transformers torch
# USE_HF_INDUSTRY=1          - Use swarupt/industry-classification for industry (local, no API cost)
# USE_HF_EMAIL_INTENT_FILTER=1 - Filter out PROMOTION/spam leads via Shoriful025/Email-Intent-Classifier
# USE_LEAD_PRECHECK=1       - Pre-validate leads before submit (avoids gateway/validator rejections; see docs/AVOID-REJECTIONS.md)
