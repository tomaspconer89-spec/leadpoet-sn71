# Lead Sorcerer Environment Variables
# Copy this file to .env and fill in your actual values

# Google Programmable Search Engine
GSE_API_KEY=your_gse_api_key_here
GSE_CX=your_gse_cx_here

# OpenRouter for LLM access
OPENROUTER_KEY=your_openrouter_key_here

# Firecrawl for web crawling
FIRECRAWL_KEY=your_firecrawl_key_here

# Data directory (optional, defaults to ./data)
LEADPOET_DATA_DIR=./data

# Skip domains already present under lead_queue/ (pass, precheck-fail, submitted)
# LEAD_QUEUE_VISITED_DIR=/path/to/repo/lead_queue
# LEADPOET_SKIP_VISITED_QUEUE_DOMAINS=1

# Persistent crawl scrape cache across Sorcerer runs (optional; main_leads sets repo/.lead_sorcerer_cache/crawl_artifacts)
# LEADPOET_CRAWL_ARTIFACTS_DIR=/path/to/crawl_artifacts
