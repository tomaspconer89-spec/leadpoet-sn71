{
  "name": "Leadpoet High-Yield B2B ICP",
  "icp_text": "Mid-market B2B SaaS in the United States (roughly 11–500 employees) with visible team or leadership pages, named growth/revenue/sales/marketing leaders, and credible business sites—not directories, marketplaces, or contact-only brochure sites. Discovery may surface Canada/UK/EU domains; gateway precheck still requires US (or existing narrow UAE exception) unless you change lead_precheck.",
  "queries": [
    "\"b2b saas\" \"team\"",
    "\"b2b saas\" \"leadership\"",
    "\"sales enablement\" software \"our team\"",
    "\"marketing automation\" SaaS leadership",
    "\"customer support software\" \"Head of Growth\"",
    "\"revenue operations software\" \"VP Revenue\"",
    "\"b2b saas\" careers marketing",
    "\"b2b saas\" \"RevOps\"",
    "\"Head of Growth\" \"b2b saas\"",
    "\"VP Revenue\" \"software company\"",
    "\"b2b saas\" careers growth",
    "\"crm software\" B2B company",
    "\"customer engagement software\" company team",
    "\"revops\" OR \"revenue operations\" b2b saas leadership",
    "\"digital agency\" \"our team\" managing director",
    "\"creative agency\" leadership team founder",
    "\"healthtech\" startup \"team\" OR \"leadership\"",
    "\"fintech\" platform \"leadership\" team",
    "site:.com \"head of growth\" \"b2b\" SaaS"
  ],
  "specific_urls": [],
  "default_contact_linkedin": "",
  "crawl": {
    "top_pages_per_domain": 3,
    "page_score_threshold": 8
